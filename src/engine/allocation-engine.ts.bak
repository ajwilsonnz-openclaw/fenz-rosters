// FENZ Overtime Allocation Engine  BlockDistance Architecture
//
// Design spec: SPEC.md
// Groups: District FF (per area), SO, SSO  all run simultaneously within each distance phase
// Blocks: 1=In-district FF callback, 2=In-district FF non-callback, 3=OOD FF callback,
//         4=OOD FF non-callback, 5=SO callback, 6=SSO callback, 7=SO non-callback, 8=SSO non-callback
// Within each Block: sweep distance phases globally (0km  max)
//   All stations move through the SAME distance phase before anyone advances
//   Within a distance phase: candidates sorted must/might  OT count  distance, assigned one-by-one
// Specialist fill runs after Block 2 (last in-district FF block)
// Preferences filter: if JSONB has entries, candidate must be in the list

import { Pool } from 'pg';
import { getShift, getCallbackType, getShiftStatus, ANCHORS, isOnLeave } from './watch-math';
import { getPool } from '../lib/db';

//  Types 

export interface Firefighter {
  id: number;
  first_name: string;
  last_name: string;
  station_id: number;
  station_name: string;
  district: string;
  area_id: number;
  watch: string;
  rank: 'FF' | 'QFF' | 'SFF' | 'SO' | 'SSO';
  qualifications: Record<string, boolean>;
  preferences: { districts: string[]; stations: string[] }; // empty = all
  want_to_work_day: boolean;
  want_to_work_night: boolean;
  ot_count_days: number;
  ot_count_nights: number;
  ot_count_callback_days: number;
  ot_count_callback_nights: number;
  ot_count_noncallback_days: number;
  ot_count_noncallback_days__w: number;
  ot_count_noncallback_nights: number;
  is_active: boolean;
}

export interface OTRequest {
  station_id: number;
  station_name: string;
  district: string;
  date: string; // YYYY-MM-DD
  shift_type: 'Day' | 'Night';
  slots: number;
  specialist_type: string | null;
}

export interface DistanceMatrix {
  [fromStationId: number]: {[toStationId: number]: number}; // [fromStationId][toStationId] = km
}

export interface Assignment {
  firefighter_id: number;
  firefighter_name: string;
  rank: string;
  home_station: string;
  distance: number;
  cascadePhase: string;
  otCount: number;
  threshold: 'must' | 'might' | 'wont';
  callback: string | null;
  qualifications: string[];
  stolenFrom?: string;
}

export interface AllocationResult {
  station_name: string;
  station_id: number;
  slots: number;
  specialist: string | null;
  assignedFirefighters: Assignment[];
  phasesUsed: string[];
}

export interface TraceEntry {
  type: 'header' | 'info' | 'debug' | 'assign' | 'skip' | 'stolen' | 'lost';
  message: string;
  detail?: string;
}

export interface AllocationRunOutput {
  stationResults: AllocationResult[];
  allFirefightersDetail: FullFFDetail[];
  watchMatrix: WatchMatrixEntry[];
  availableOvertimes: OvertimeStatus[];
  traces: Record<string, TraceEntry[]>; // stationName  trace entries
}

export interface FullFFDetail {
  id: number;
  name: string;
  watch: string;
  rank: string;
  homeStation: string;
  otStation: string;
  distance: number;
  otDays: number;
  otNights: number;
  cbDays: number;
  cbNights: number;
  ncDays: number;
  ncNights: number;
  isAssigned: boolean;
  isEligible: boolean;
  cascadePhase: string;
  callback: string | null;
  quals: string[];
  stolenFrom: string | null;
  threshold: string;
}

export interface WatchMatrixEntry {
  watch: string;
  shift: string;
  statusLabel: string;
  onLeave: boolean;
  callback: string | null;
  eligible: boolean;
  reason: string;
}

export interface OvertimeStatus {
  name: string;
  assigned: boolean;
  overtimeStation: string;
}

//  Block Definitions 

type RankFilter = 'FF' | 'SO' | 'SSO' | 'FF+SO' | 'FF+SSO' | 'SO+SSO';

interface BlockDef {
  id: number;
  phase: string;
  rankFilter: RankFilter;
  inDistrict: boolean | 'any'; // true=in-district only, 'any'=any district
  isCallback: boolean;
  otCounter: 'callback' | 'noncallback';
  note: string;
}

const BLOCKS: BlockDef[] = [
  { id: 1, phase: 'ff-callback',          rankFilter: 'FF',        inDistrict: true,   isCallback: true,  otCounter: 'callback',    note: 'In-district FF callback' },
  { id: 2, phase: 'ff-noncallback',       rankFilter: 'FF',        inDistrict: true,   isCallback: false, otCounter: 'noncallback', note: 'In-district FF non-callback' },
  { id: 3, phase: 'ood-ff-callback',      rankFilter: 'FF',        inDistrict: 'any',  isCallback: true,  otCounter: 'callback',    note: 'Out-of-district FF callback' },
  { id: 4, phase: 'ood-ff-noncallback',   rankFilter: 'FF',        inDistrict: 'any',  isCallback: false, otCounter: 'noncallback', note: 'Out-of-district FF non-callback' },
  { id: 5, phase: 'so-callback',          rankFilter: 'SO+FF',     inDistrict: 'any',  isCallback: true,  otCounter: 'callback',    note: 'SO callback (all districts, includes FF/SSO)' },
  { id: 6, phase: 'sso-callback',         rankFilter: 'SSO+SO',    inDistrict: 'any',  isCallback: true,  otCounter: 'callback',    note: 'SSO callback (all districts, includes SO)' },
  { id: 7, phase: 'so-noncallback',       rankFilter: 'SO+FF',     inDistrict: 'any',  isCallback: false, otCounter: 'noncallback', note: 'SO non-callback (all districts)' },
  { id: 8, phase: 'sso-noncallback',      rankFilter: 'SSO+SO',    inDistrict: 'any',  isCallback: false, otCounter: 'noncallback', note: 'SSO non-callback (all districts)' },
];

//  Helper Functions 

function getRank(ff: Firefighter): 'FF' | 'SO' | 'SSO' {
  if (ff.rank === 'SO') return 'SO';
  if (ff.rank === 'SSO') return 'SSO';
  return 'FF';
}

function rankMatchesFilter(rank: 'FF' | 'SO' | 'SSO', filter: RankFilter): boolean {
  switch (filter) {
    case 'FF':   return rank === 'FF';
    case 'SO':   return rank === 'SO';
    case 'SSO':  return rank === 'SSO';
    case 'FF+SO': return rank === 'FF' || rank === 'SO';
    case 'FF+SSO': return rank === 'FF' || rank === 'SSO';
    case 'SO+SSO': return rank === 'SO' || rank === 'SSO';
  }
}

function getOTCount(ff: Firefighter, counter: 'callback' | 'noncallback', shiftType: 'Day' | 'Night'): number {
  if (counter === 'callback') {
    return shiftType === 'Day' ? ff.ot_count_callback_days : ff.ot_count_callback_nights;
  }
  return shiftType === 'Day' ? ff.ot_count_noncallback_days : ff.ot_count_noncallback_nights;
}

export function getShiftForWatch(watch: string, dateStr: string): 'Day' | 'Night' | 'Off' {
  return getShift(watch, new Date(dateStr));
}

export function getCallbackForWatch(watch: string, dateStr: string): string | null {
  return getCallbackType(watch, new Date(dateStr));
}

export function canDoOT(ff: Firefighter, dateStr: string, shiftType: 'Day' | 'Night'): { pass: boolean; reason: string } {
  const shift = getShiftForWatch(ff.watch, dateStr);
  if (shift === 'Off' && isOnLeave(ff.watch, new Date(dateStr))) {
    return { pass: false, reason: 'On Leave' };
  }
  // #3-AfterLastNight  Day OT excluded
  const cb = getCallbackForWatch(ff.watch, dateStr);
  if (cb === '#3-AfterLastNight' && shiftType === 'Day') {
    return { pass: false, reason: 'Between Nights  Day OT excluded' };
  }
  // #2a-EveningDay2  Day OT excluded
  if (cb === '#2a-EveningDay2' && shiftType === 'Day') {
    return { pass: false, reason: '#2a EveningDay2 excludes Day' };
  }
  // #2b-DayOfNight1  Day OT excluded
  if (cb === '#2b-DayOfNight1' && shiftType === 'Day') {
    return { pass: false, reason: '#2b DayOfNight1 excludes Day' };
  }
  // Regular working shift mismatch (non-callback context)
  if (shift !== 'Off' && cb === null) {
    if (shiftType === 'Day' && shift === 'Night') return { pass: false, reason: 'On Night shift' };
    if (shiftType === 'Night' && shift === 'Day') return { pass: false, reason: 'On Day shift' };
  }
  return { pass: true, reason: 'Watch-eligible' };
}

function checkQualifications(ff: Firefighter, quals: string[]): boolean {
  if (!quals || quals.length === 0) return true;
  for (const q of quals) {
    if (!ff.qualifications[q]) return false;
  }
  return true;
}

function checkPreferences(ff: Firefighter, otStationName: string, otDistrict: string): boolean {
  const { districts, stations } = ff.preferences;
  if ((!districts || districts.length === 0) && (!stations || stations.length === 0)) {
    return true; // No restrictions
  }
  if (stations && stations.length > 0) {
    return stations.includes(otStationName);
  }
  if (districts && districts.length > 0) {
    return districts.includes(otDistrict);
  }
  return true;
}

export function getDistance(fromStationId: number, toStationId: number, matrix: DistanceMatrix): number {
  if (fromStationId === toStationId) return 0;
  const from = matrix[fromStationId];
  if (!from) return 999;
  const dist = from[toStationId];
  return dist !== undefined ? dist : 999;
}

function parseNzDate(dateStr: string): Date {
  const [y, m, d] = dateStr.split('-').map(Number);
  return new Date(y, m - 1, d);
}

//  Must/Might/Won't Threshold 

export function computeMustMightWonThreshold(
  candidates: { ff: Firefighter; distance: number; otCount: number }[],
  slots: number
): Map<number, 'must' | 'might' | 'wont'> {
  const result = new Map<number, 'must' | 'might' | 'wont'>();
  if (candidates.length === 0 || slots <= 0) return result;

  // Sort by OT count, then by distance (ascending) for tiebreaking
  const sorted = [...candidates].sort((a, b) => {
    if (a.otCount !== b.otCount) return a.otCount - b.otCount;
    return a.distance - b.distance;
  });

  let cumulative = 0;
  for (const c of sorted) {
    cumulative += 1;
    if (cumulative <= slots) {
      result.set(c.ff.id, 'must');
    } else {
      result.set(c.ff.id, 'might');
    }
  }
  return result;
}

//  Load All Firefighters 

export async function loadAllFirefighters(pool: Pool): Promise<Firefighter[]> {
  const result = await pool.query<Record<string, unknown>>(`
    SELECT
      ff.id,
      ff.first_name,
      ff.last_name,
      ff.station_id,
      s.name AS station_name,
      s.area_id,
      a.name AS district,
      ff.watch,
      ff.rank,
      ff.qualifications,
      ff.preferences,
      ff.want_to_work_day,
      ff.want_to_work_night,
      ff.ot_count_days,
      ff.ot_count_nights,
      ff.ot_count_callback_days,
      ff.ot_count_callback_nights,
      ff.ot_count_noncallback_days,
      ff.ot_count_noncallback_nights,
      ff.is_active
    FROM firefighters ff
    JOIN stations s ON ff.station_id = s.id
    JOIN areas a ON s.area_id = a.id
    WHERE ff.is_active = true
    ORDER BY ff.last_name, ff.first_name
  `);
  return result.rows.map(row => ({
    ...row,
    qualifications: typeof row.qualifications === 'string'
      ? JSON.parse(row.qualifications) : (row.qualifications || {}),
    preferences: typeof row.preferences === 'string'
      ? JSON.parse(row.preferences) : (row.preferences || { districts: [], stations: [] }),
    rank: row.rank as Firefighter['rank'],
  }));
}

//  Load Distance Matrix 

export async function loadDistanceMatrix(pool: Pool): Promise<DistanceMatrix> {
  const result = await pool.query<{ station_id: number; distances: Record<string, number> }>(`
    SELECT station_id, distances FROM station_distances
  `);
  const matrix: DistanceMatrix = {};
  for (const row of result.rows) {
    // distances is JSONB { stationB_id: km } where keys are station IDs as strings
    const distObj: Record<number, number> = {};
    for (const [k, v] of Object.entries(row.distances)) {
      distObj[Number(k)] = Number(v);
    }
    matrix[row.station_id] = distObj;
  }
  return matrix;
}

//  Core Allocation Engine 

export async function allocateForOTRequest(
  requests: OTRequest[],
  allFirefighters: Firefighter[],
  distanceMatrix: DistanceMatrix,
  existingAssigned: Set<number> = new Set()
): Promise<AllocationResult[]> {
  const results: AllocationResult[] = [];
  const assignedThisRun = new Set<number>(existingAssigned);
  const traces: Record<string, TraceEntry[]> = {};

  // Initialize trace arrays for each station
  for (const req of requests) {
    traces[req.station_name] = [];
  }

  // Determine max distance in the matrix
  let maxDistance = 0;
  for (const from of Object.values(distanceMatrix)) {
    for (const km of Object.values(from)) {
      if (km > maxDistance) maxDistance = km;
    }
  }

  //  Process each Block 
  for (const block of BLOCKS) {
    const trace: TraceEntry = { type: 'header', message: `=== Block ${block.id}: ${block.phase} ===` };
    for (const req of requests) traces[req.station_name].push(trace);

    //  Distance phase sweep (0km  maxDistance) 
    // ALL stations move through the same distance phase simultaneously
    for (let dist = 0; dist <= maxDistance; dist++) {
      let anyStationHasCandidatesAtThisDist = false;

      for (const req of requests) {
        if (assignedThisRun.has(-req.station_id)) continue; // already fully assigned (hack: use negative ID)
        const slotsFilled = results
          .filter(r => r.station_id === req.station_id)
          .reduce((sum, r) => sum + r.assignedFirefighters.length, 0);
        if (slotsFilled >= req.slots) {
          assignedThisRun.add(-req.station_id); // mark as done
          continue;
        }

        const slotsRemaining = req.slots - slotsFilled;
        if (slotsRemaining <= 0) continue;

        // Collect candidates for this (block, distance) combination
        const candidates: { ff: Firefighter; distance: number; otCount: number }[] = [];

        for (const ff of allFirefighters) {
          // Skip already assigned
          if (assignedThisRun.has(ff.id)) continue;

          // Skip if not on the relevant watch for this block
          const shift = getShiftForWatch(ff.watch, req.date);
          const watchCb = getCallbackForWatch(ff.watch, req.date);

          if (block.isCallback) {
            if (!watchCb) continue; // must be on callback
          } else {
            if (watchCb) continue; // must NOT be on callback
          }

          // Watch eligibility
          const eligible = canDoOT(ff, req.date, req.shift_type);
          if (!eligible.pass) continue;

          // Rank filter
          if (!rankMatchesFilter(getRank(ff), block.rankFilter)) continue;

          // In-district filter (Blocks 1-2 only)
          if (block.inDistrict === true && ff.district !== req.district) continue;

          // Distance check
          const distance = getDistance(ff.station_id, req.station_id, distanceMatrix);
          if (distance !== dist) continue;

          // Qualifications (specialist check)
          const requiredQuals = req.specialist_type ? [req.specialist_type] : [];
          if (!checkQualifications(ff, requiredQuals)) continue;

          // Preferences
          if (!checkPreferences(ff, req.station_name, req.district)) continue;

          // Non-callback: must be off-duty OR want_to_work AND on matching shift
          if (!block.isCallback) {
            if (shift !== 'Off') {
              const wantField = req.shift_type === 'Day' ? ff.want_to_work_day : ff.want_to_work_night;
              if (!wantField) continue;
            }
          }

          const otCount = getOTCount(ff, block.otCounter, req.shift_type);
          candidates.push({ ff, distance, otCount });
        }

        if (candidates.length === 0) {
          traces[req.station_name].push({
            type: 'info',
            message: `dist-${dist}: No candidates at ${dist}km for ${block.phase}`,
          });
          continue;
        }

        anyStationHasCandidatesAtThisDist = true;

        // Compute must/might thresholds
        const threshold = computeMustMightWonThreshold(candidates, slotsRemaining);

        // Sort: must first  lowest OT count  distance (for tiebreaker within threshold group)
        const sorted = [...candidates].sort((a, b) => {
          const ta = threshold.get(a.ff.id)!;
          const tb = threshold.get(b.ff.id)!;
          if (ta !== tb) return ta === 'must' ? -1 : 1;
          if (a.otCount !== b.otCount) return a.otCount - b.otCount;
          return a.distance - b.distance;
        });

        traces[req.station_name].push({
          type: 'info',
          message: `dist-${dist}: ${sorted.length} candidates for ${block.phase}, ${slotsRemaining} slots`,
        });

        let assigned = 0;
        for (const c of sorted) {
          if (assigned >= slotsRemaining) break;
          if (threshold.get(c.ff.id) === 'wont') break;

          assignedThisRun.add(c.ff.id);
          assigned++;

          const assignment: Assignment = {
            firefighter_id: c.ff.id,
            firefighter_name: `${c.ff.first_name} ${c.ff.last_name}`,
            rank: c.ff.rank,
            home_station: c.ff.station_name,
            distance: c.distance,
            cascadePhase: block.phase,
            otCount: c.otCount,
            threshold: threshold.get(c.ff.id)!,
            callback: getCallbackForWatch(c.ff.watch, req.date),
            qualifications: Object.keys(c.ff.qualifications).filter(k => c.ff.qualifications[k]),
          };

          // Add to results
          let stationResult = results.find(r => r.station_id === req.station_id);
          if (!stationResult) {
            stationResult = {
              station_name: req.station_name,
              station_id: req.station_id,
              slots: req.slots,
              specialist: req.specialist_type,
              assignedFirefighters: [],
              phasesUsed: [],
            };
            results.push(stationResult);
          }
          stationResult.assignedFirefighters.push(assignment);
          if (!stationResult.phasesUsed.includes(block.phase)) {
            stationResult.phasesUsed.push(block.phase);
          }

          traces[req.station_name].push({
            type: 'assign',
            message: `ASSIGNED ${c.ff.first_name} ${c.ff.last_name} (${getRank(c.ff)}) dist=${c.distance}km OT=${c.otCount} cbD=${threshold.get(c.ff.id)}`,
            detail: `${block.phase} | ${req.shift_type}`,
          });
        }

        if (assigned === 0) {
          traces[req.station_name].push({
            type: 'info',
            message: `dist-${dist}: All candidates were 'might'/'wont'  no room`,
          });
        }
      }

      // Only advance to next distance when ALL stations have exhausted this distance
      if (!anyStationHasCandidatesAtThisDist && dist < maxDistance) {
        // All stations done at this distance  skip to next
        continue;
      }
    }
  }

  return results;
}

//  Specialist Fill (Post-Block 2) 
// Note: In the new architecture, specialist fill is integrated into the main
// allocation loop  stations declare specialist_type, and qualifications are
// checked during candidate collection. No separate pass needed.

export async function checkAndFillSpecialistStations(
  allFirefighters: Firefighter[],
  distanceMatrix: DistanceMatrix,
  existingAssigned: Set<number>
): Promise<AllocationResult[]> {
  // In the new architecture, specialist stations are handled during allocation.
  // This function is kept for compatibility but is a no-op.
  return [];
}

//  Main Export 

export async function runAllocation(
  requests: OTRequest[],
  pool: Pool
): Promise<{
  stationResults: AllocationResult[];
  traces: Record<string, TraceEntry[]>;
}> {
  const [allFFs, distMatrix] = await Promise.all([
    loadAllFirefighters(pool),
    loadDistanceMatrix(pool),
  ]);

  const stationResults = await allocateForOTRequest(requests, allFFs, distMatrix, new Set());

  return { stationResults, traces: {} };
}